# ── Gemini API ────────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com → "Get API Key"
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Models ────────────────────────────────────────────────────────────────────
ORCHESTRATOR_MODEL=gemini-2.5-pro
SPECIALIST_MODEL=gemini-2.5-flash
EVALUATOR_MODEL=gemini-2.5-flash

# ── Environment switch ────────────────────────────────────────────────────────
# "local"  → reads PDFs/CSVs from local disk
# "cloud"  → reads PDFs/CSVs from GCS bucket
ENVIRONMENT=local

# ── Local file paths (only used when ENVIRONMENT=local) ──────────────────────
PDF_DIR=./data/pdfs
CSV_DIR=./data/csvs
CHROMA_DIR=./chroma_db
SCHEMA_CACHE_PATH=./memory/schema_memory.json
EVAL_RESULTS_PATH=./outputs/eval_results.json

# ── Cloud paths (only used when ENVIRONMENT=cloud) ───────────────────────────
# GCS bucket name — no gs:// prefix
GCS_BUCKET=hos-agent-files-your-project-id

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
